####### Compile

main.o: ../MineServer/main.cpp ../MineServer/mineserver.h \
		../common/messages.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o main.o ../MineServer/main.cpp

mineserver.o: ../MineServer/mineserver.cpp ../MineServer/mineserver.h \
		../common/messages.h \
		../MineServer/miner.h \
		../MineServer/logger.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o mineserver.o ../MineServer/mineserver.cpp

miner.o: ../MineServer/miner.cpp ../MineServer/miner.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o miner.o ../MineServer/miner.cpp

logger.o: ../MineServer/logger.cpp ../MineServer/logger.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o logger.o ../MineServer/logger.cpp

messages.o: ../common/messages.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o messages.o ../common/messages.cpp

moc_mineserver.o: moc_mineserver.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_mineserver.o moc_mineserver.cpp

moc_miner.o: moc_miner.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_miner.o moc_miner.cpp

